# =====================================================
# .gitignore para proyecto Unity
# Basado en el oficial de github.com/github/gitignore
# =====================================================

# Carpetas generadas por Unity (se regeneran al abrir el proyecto)
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Caches de empaquetado/compilación
[Aa]ssets/[Aa]ssetStoreTools*
[Aa]ssets/Plugins/Editor/JetBrains*

# Archivos generados por IDEs (Visual Studio, Rider, VSCode)
.vs/
.vscode/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.slnx

# Builds binarios
*.apk
*.aab
*.unitypackage
*.app
*.exe

# Crashlytics generated file
crashlytics-build.properties

# Packages
ExportedObj/
.consulo/
*.csproj.bak

# Archivos del sistema
.DS_Store
Thumbs.db
desktop.ini

# Archivos de logs y backups
*.log
*.bak
*.orig

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*
